{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_body_skip_to_content %}{% endblock %}
{% block base_esi_header %}{% endblock %}
{% block base_navigation_styling %}{% endblock %}
{% block base_flashbags %}{% endblock %}
{% block base_add_to_cart_alert_template %}{% endblock %}
{% block base_breadcrumb %}{% endblock %}
{% block base_esi_footer %}{% endblock %}
{% block base_scroll_up %}{% endblock %}
{% block base_cookie_permission %}{% endblock %}
{% block base_pseudo_modal %}{% endblock %}
{% block base_speculation_rules %}{% endblock %}

{% block base_body %}
    <style>
        html, body {
                background-color: transparent !important;
        }
    </style>
    {% set blurElysiumBreakpoints = {
        mobile: 'xs',
        tablet: 'md',
        desktop: 'xl'
    } %}

    {% if config('BlurElysiumSlider.breakpoints') %}
        {% set blurElysiumBreakpoints = blurElysiumBreakpoints|merge(
            config('BlurElysiumSlider.breakpoints')
        ) %}
    {% endif %}

    <div class="blur-elysium-slide-preview-wrapper p-4">
        {% sw_include '@Storefront/storefront/component/blur-elysium-slide/default/slide.html.twig' with {
            slideData: slideData,
            lazyLoading: false
        } %}
    </div>

    <script>
        (function () {
            // TODO: adjust origin validation for production / multi-domain setups
            var ALLOWED_ORIGIN = 'http://localhost:8000';
            var SLIDE_ID = '{{ slideData.id|escape('js') }}';

            function getSlideElement() {
                return document.querySelector('[data-elysium-slide-id="' + SLIDE_ID + '"]');
            }

            function updateBaseStyles(slide, element) {
                if (!slide.slideSettings || !slide.slideSettings.slide) {
                    return;
                }

                var settings = slide.slideSettings.slide;
                var styles = {};

                if (settings.bgColor) {
                    styles['--slide-bg-color'] = settings.bgColor;
                }
                if (settings.bgGradient) {
                    if (settings.bgGradient.startColor) {
                        styles['--slide-gradient-color-start'] = settings.bgGradient.startColor;
                    }
                    if (settings.bgGradient.endColor) {
                        styles['--slide-gradient-color-end'] = settings.bgGradient.endColor;
                    }
                    if (settings.bgGradient.gradientDeg) {
                        styles['--slide-gradient-deg'] = settings.bgGradient.gradientDeg + 'deg';
                    }
                }
                if (settings.headline && settings.headline.color) {
                    styles['--headline-color'] = settings.headline.color;
                }
                if (settings.description && settings.description.color) {
                    styles['--description-color'] = settings.description.color;
                }
                if (settings.container && settings.container.bgColor) {
                    styles['--container-bg-color'] = settings.container.bgColor;
                }

                Object.keys(styles).forEach(function (prop) {
                    element.style.setProperty(prop, styles[prop]);
                });
            }

            function updateViewportStyles(slide, device, element) {
                if (!slide.slideSettings || !slide.slideSettings.viewports || !slide.slideSettings.viewports[device]) {
                    return;
                }

                var options = slide.slideSettings.viewports[device];
                var styles = {};

                if (options.slide) {
                    if (options.slide.paddingX) {
                        styles['--slide-padding-x'] = options.slide.paddingX + 'px';
                    }
                    if (options.slide.paddingY) {
                        styles['--slide-padding-y'] = options.slide.paddingY + 'px';
                    }
                    if (options.slide.alignItems) {
                        styles['--slide-align-items'] = options.slide.alignItems;
                    }
                    if (options.slide.justifyContent) {
                        styles['--slide-justify-content'] = options.slide.justifyContent;
                    }
                    if (options.slide.borderRadius) {
                        styles['--slide-border-radius'] = options.slide.borderRadius + 'px';
                    }
                }

                if (options.container) {
                    if (options.container.gap) {
                        styles['--container-gap'] = options.container.gap + 'px';
                    }
                    if (options.container.paddingX) {
                        styles['--container-padding-x'] = options.container.paddingX + 'px';
                    }
                    if (options.container.paddingY) {
                        styles['--container-padding-y'] = options.container.paddingY + 'px';
                    }
                    if (options.container.borderRadius) {
                        styles['--container-border-radius'] = options.container.borderRadius + 'px';
                    }
                    if (options.container.alignItems) {
                        styles['--container-align-items'] = options.container.alignItems;
                    }
                    if (options.container.justifyContent) {
                        styles['--container-justify-content'] = options.container.justifyContent;
                    }
                    if (options.container.columnWrap === true) {
                        styles['--container-direction'] = 'column';
                    } else if (options.container.columnWrap === false) {
                        styles['--container-direction'] = 'row';
                    }
                }

                if (options.headline && options.headline.fontSize) {
                    styles['--headline-font-size'] = options.headline.fontSize + 'px';
                }

                if (options.description && options.description.fontSize) {
                    styles['--description-font-size'] = options.description.fontSize + 'px';
                }

                if (options.content) {
                    if (options.content.textAlign) {
                        styles['--content-text-align'] = options.content.textAlign;
                    }
                    if (options.content.paddingX) {
                        styles['--content-padding-x'] = options.content.paddingX + 'px';
                    }
                    if (options.content.paddingY) {
                        styles['--content-padding-y'] = options.content.paddingY + 'px';
                    }
                }

                Object.keys(styles).forEach(function (prop) {
                    element.style.setProperty(prop, styles[prop]);
                });
            }

            function updateTextContent(slide) {
                var headlineEl = document.querySelector('.blur-elysium-slide-headline');
                if (headlineEl && slide.title !== undefined) {
                    headlineEl.innerHTML = slide.title;
                }

                var descriptionEl = document.querySelector('.blur-elysium-slide-description');
                if (descriptionEl && slide.description !== undefined) {
                    descriptionEl.innerHTML = slide.description;
                }

                var btnEl = document.querySelector('.blur-elysium-slide-main-btn');
                if (btnEl) {
                    if (slide.buttonLabel !== undefined) {
                        btnEl.textContent = slide.buttonLabel;
                    }
                    if (slide.url !== undefined) {
                        btnEl.setAttribute('href', slide.url);
                    }
                }

                var overlayEl = document.querySelector('.blur-elysium-slide-link-overlay');
                if (overlayEl && slide.url !== undefined) {
                    overlayEl.setAttribute('href', slide.url);
                }
            }

            function updateSlide(data) {
                var slide = data.slide;
                var device = data.device || 'desktop';
                var element = getSlideElement();

                if (!element || !slide) {
                    return;
                }

                updateBaseStyles(slide, element);
                updateViewportStyles(slide, device, element);
                updateTextContent(slide);
            }

            window.addEventListener('message', function (event) {
                if (event.origin !== ALLOWED_ORIGIN) {
                    return;
                }

                if (event.data && event.data.type === 'elysium-slide-update') {
                    updateSlide(event.data);
                }
            });
        })();
    </script>
{% endblock %}
