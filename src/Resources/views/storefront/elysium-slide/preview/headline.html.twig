{% set headlineElement = slideData.slideSettings.slide.headline.element|default('div') %}

{% if slideData.slideSettings.slide.linking.type is same as('product')
      and slideData.slideSettings.slide.linking.showProductTitle is same as(true)
      and slideData.product.translated.name %}
    {% set headlineContent = slideData.product.translated.name %}
{% else %}
    {% set headlineContent = slideData.title|default('') %}
{% endif %}

{% if headlineContent %}
    <{{headlineElement}} class="blur-elysium-slide-headline" data-elysium-slide-headline="{{ slideData.id }}">
        {{ headlineContent|raw }}
    </{{headlineElement}}>
{% endif %}
