{% set blurElysiumBreakpoints = {
    mobile: 'xs',
    tablet: 'md',
    desktop: 'xl'
} %}

{% if config('BlurElysiumSlider.breakpoints') %}
    {% set blurElysiumBreakpoints = blurElysiumBreakpoints|merge(config('BlurElysiumSlider.breakpoints')) %}
{% endif %}

{% set slideCovers = {} %}
{% if slideData.slideCoverMobile %}
    {% set slideCovers = slideCovers|merge({ mobile: slideData.slideCoverMobile }) %}
{% endif %}
{% if slideData.slideCoverTablet %}
    {% set slideCovers = slideCovers|merge({ tablet: slideData.slideCoverTablet }) %}
{% endif %}
{% if slideData.slideCover %}
    {% set slideCovers = slideCovers|merge({ desktop: slideData.slideCover }) %}
{% endif %}

{% if slideData.slideCoverVideo %}
    <video autoplay muted loop
        class="blur-elysium-slide-cover-video"
        data-elysium-slide-cover-video="{{ slideData.id }}"
        style="border-radius: var(--slide-border-radius, 0px);">
        <source src="{{slideData.slideCoverVideo.url}}" type="{{slideData.slideCoverVideo.mimeType}}">
    </video>
{% elseif slideCovers|length > 0 %}
    {% set slideCoverAlt = slideData.slideCoverMobile.alt|default(
        slideData.slideCoverTablet.alt|default(
            slideData.slideCover.alt|default(null)
        )
    ) %}
    {% set slideCoverTitle = slideData.slideCoverMobile.title|default(
        slideData.slideCoverTablet.title|default(
            slideData.slideCover.title|default(null)
        )
    ) %}
    {% set slideCoverLabel = slideCoverAlt %}

    {% if slideData.contentSettings.slideCover.alt %}
        {% set slideCoverAlt = slideData.contentSettings.slideCover.alt %}
        {% set slideCoverLabel = slideData.contentSettings.slideCover.alt %}
    {% endif %}

    {% if slideData.contentSettings.slideCover.title %}
        {% set slideCoverTitle = slideData.contentSettings.slideCover.title %}
    {% endif %}

    <picture class="blur-elysium-slide-cover-picture">
        {% if slideData.slideCover %}
            <source
                {% if slideData.slideCover.thumbnails|length > 0 %}
                    srcset="{{ create_srcset(slideData.slideCover.thumbnails) }}"
                {% else %}
                    srcset="{{ slideData.slideCover.url }}"
                {% endif %}
                media="screen and (min-width:{{ theme_config('breakpoint.' ~ blurElysiumBreakpoints.desktop)~'px' }})" />
        {% endif %}

        {% if slideData.slideCoverTablet %}
            <source
                {% if slideData.slideCoverTablet.thumbnails|length > 0 %}
                    srcset="{{ create_srcset(slideData.slideCoverTablet.thumbnails) }}"
                {% else %}
                    srcset="{{ slideData.slideCoverTablet.url }}"
                {% endif %}
                media="screen and (min-width:{{ theme_config('breakpoint.' ~ blurElysiumBreakpoints.tablet)~'px' }})" />
        {% endif %}

        {% if slideData.slideCoverMobile %}
            <img
                src="{{ slideData.slideCoverMobile.url }}"
                {% if slideData.slideCoverMobile.thumbnails|length > 0 %}
                    srcset="{{ create_srcset(slideData.slideCoverMobile.thumbnails) }}"
                {% endif %}
                width="100%"
                height="100%"
                {% if slideCoverAlt %}alt="{{ slideCoverAlt }}"{% endif %}
                {% if slideCoverTitle %}title="{{ slideCoverTitle }}"{% endif %}
                {% if slideCoverLabel %}aria-label="{{ slideCoverLabel }}"{% endif %}
                class="blur-elysium-slide-cover-image"
                data-elysium-slide-cover-image="{{ slideData.id }}"
                style="border-radius: var(--slide-border-radius, 0px);" />
        {% else %}
            <img
                src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
                width="100%"
                height="100%"
                class="blur-elysium-slide-cover-image"
                data-elysium-slide-cover-image="{{ slideData.id }}"
                style="border-radius: var(--slide-border-radius, 0px);" />
        {% endif %}
    </picture>
{% endif %}
