{% block blur_elysium_slide_link_overlay %}
    {% if slideData.slideSettings.slide.linking.overlay is same as( true ) and actionMainUrl %}
        <a href="{{ isPreviewMode is defined and isPreviewMode ? '#' : actionMainUrl }}"
            class="blur-elysium-slide-link-overlay"
            data-elysium-slide-link-overlay="{{ slideData.id }}"
            aria-label="{{ headlineContent }}"
            {% if isPreviewMode is defined and isPreviewMode %}
                onclick="return false"
            {% endif %}
            {% if slideData.slideSettings.slide.linking.openExternal is same as(true) %}
                target="_blank"
                rel="noopener"
            {% endif %}>
        </a>
    {% endif %}
{% endblock %}