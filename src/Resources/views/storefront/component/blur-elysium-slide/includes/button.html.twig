{% set linking = slideData.slideSettings.slide.linking %}
{% set actionMainUrl = slideData.url|default('') %}
{% set actionMainLabel = slideData.buttonLabel|default('') %}
{% set showActions = actionMainUrl and linking.overlay is not same as(true) and actionMainLabel %}

{% if slideData.slideSettings.slide.linking.type is same as('product') %}
    {% if slideData.product.id %}
        {% set actionMainUrl = seoUrl('frontend.detail.page', {'productId': slideData.product.id}) %}
    {% endif %}
    {% if linking.overlay is not same as(true) %}
        {% set showActions = true %}
    {% endif %}
    {% if actionMainLabel is empty %}
        {% set actionMainLabel = 'blurElysiumSlides.buttonLabelProduct'|trans %}
    {% endif %}
{% endif %}

{% if showActions %}
    {% set mainBtnClasses = [
        'blur-elysium-slide-main-btn',
        'btn',
        linking.buttonAppearance ? 'btn-' ~ linking.buttonAppearance : null,
        linking.buttonSize and linking.buttonSize != 'md' ? 'btn-' ~ linking.buttonSize : null
    ] %}
    <div class="blur-elysium-slide-actions">
        <a href="{{ isPreviewMode is defined and isPreviewMode ? '#' : actionMainUrl }}"
            title="{{ actionMainLabel }}"
            class="{{ mainBtnClasses|join(' ') }}"
            data-elysium-slide-button="{{ slideData.id }}"
            {% if isPreviewMode is defined and isPreviewMode %}
                onclick="return false"
            {% endif %}
            {% if linking.openExternal is same as(true) %}target="_blank" rel="noopener"{% endif %}>
            {{ actionMainLabel }}
        </a>
    </div>
{% endif %}
