{% macro outputViewportVars(options, mappings) %}
    {# Simple value mappings (path → cssVar with optional unit) #}
    {% for mapping in mappings.simple|default(mappings) %}
        {% set group = attribute(options, mapping.group) %}
        {% if group %}
            {% set value = attribute(group, mapping.key) %}
            {% if value is not null and value is not same as(false) and value is not same as('') %}
                {% if mapping.zeroValue is defined and value is same as(0) %}
                    {{ mapping.var }}: {{ mapping.zeroValue }};
                {% else %}
                    {{ mapping.var }}: {{ value }}{{ mapping.unit ? mapping.unit : '' }};
                {% endif %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {# Column wrap direction #}
    {% if options.container.columnWrap is same as(true) %}
        --container-direction: column;
    {% elseif options.container.columnWrap is same as(false) %}
        --container-direction: row;
    {% endif %}

    {# Image / content order swap #}
    {% if options.container.order is same as('reverse') %}
        --image-order: 1;
        --content-order: 2;
    {% elseif options.container.order is same as('default') %}
        --image-order: 2;
        --content-order: 1;
    {% endif %}

    {# Content flex sizing #}
    {% if options.content.maxWidth is defined
          and options.content.maxWidth is not null
          and options.content.maxWidth is not same as('') %}
        {% if options.content.maxWidth is same as(0) %}
            --content-flex-basis: 0%;
            --content-max-w: auto;
            --content-flex-grow: 1;
        {% else %}
            --content-flex-basis: {{ options.content.maxWidth }}px;
            --content-max-w: {{ options.content.maxWidth }}px;
            --content-flex-grow: 0;
        {% endif %}
    {% endif %}

    {# Cover media mappings (dynamic keys) #}
    {% if options.coverMedia %}
        {% for key, value in options.coverMedia|filter(v => v is not empty) %}
            {{ '--cover-' ~ camel_to_kebab_case(key) }}: {{ value }};
        {% endfor %}
    {% endif %}
{% endmacro %}

{% set viewportMappings = styleMappings|default({
    simple: [
        { group: 'slide',       key: 'paddingX',       var: '--slide-padding-x', unit: 'px' },
        { group: 'slide',       key: 'paddingY',       var: '--slide-padding-y', unit: 'px' },
        { group: 'slide',       key: 'alignItems',     var: '--slide-align-items' },
        { group: 'slide',       key: 'justifyContent', var: '--slide-justify-content' },
        { group: 'slide',       key: 'borderRadius',   var: '--slide-border-radius', unit: 'px' },
        { group: 'container',   key: 'gap',            var: '--container-gap', unit: 'px' },
        { group: 'container',   key: 'paddingX',       var: '--container-padding-x', unit: 'px' },
        { group: 'container',   key: 'paddingY',       var: '--container-padding-y', unit: 'px' },
        { group: 'container',   key: 'borderRadius',   var: '--container-border-radius', unit: 'px' },
        { group: 'container',   key: 'alignItems',     var: '--container-align-items' },
        { group: 'container',   key: 'justifyContent', var: '--container-justify-content' },
        { group: 'container',   key: 'maxWidth',       var: '--container-max-width', unit: 'px', zeroValue: 'auto' },
        { group: 'image',       key: 'maxWidth',       var: '--image-max-w', unit: 'px', zeroValue: 'auto' },
        { group: 'image',       key: 'justifyContent', var: '--image-justify-content' },
        { group: 'content',     key: 'textAlign',      var: '--content-text-align' },
        { group: 'content',     key: 'paddingX',       var: '--content-padding-x', unit: 'px' },
        { group: 'content',     key: 'paddingY',       var: '--content-padding-y', unit: 'px' },
        { group: 'headline',    key: 'fontSize',       var: '--headline-font-size', unit: 'px' },
        { group: 'description', key: 'fontSize',       var: '--description-font-size', unit: 'px' }
    ]
}) %}

{% if selectorClass is not defined %}
    {% set selectorClass = '.blur-elysium-slide' %}
{% endif %}

{% set slideStyles = {
    '--slide-bg-color': slideData.slideSettings.slide.bgColor,
    '--slide-gradient-color-start': slideData.slideSettings.slide.bgGradient.startColor ?: 'transparent',
    '--slide-gradient-color-end': slideData.slideSettings.slide.bgGradient.endColor ?: 'transparent',
    '--slide-gradient-deg': slideData.slideSettings.slide.bgGradient.gradientDeg ? slideData.slideSettings.slide.bgGradient.gradientDeg ~ 'deg' : null,
    '--container-bg-color': slideData.slideSettings.container.bgColor,
    '--description-color': slideData.slideSettings.slide.description.color,
    '--headline-color': slideData.slideSettings.slide.headline.color
} %}

{% set slideViewportStyles = slideData.slideSettings.viewports %}

{% set presentationMedia = slideData.presentationMedia %}

{% if slideData.product is not same as(null) and slideData.slideSettings.slide.linking.type is same as('product') %}
    {% if slideData.product.cover and slideData.presentationMedia is null %}
        {% set presentationMedia = slideData.product.cover.media %}
    {% endif %}
{% endif %}

{% apply spaceless %}
    {% block blur_elysium_slide_style %}
        <style id="style-{{ slideData.id }}" style="display:none !important; visibility:hidden !important;">
            {% block blur_elysium_slide_style_prepend %}{% endblock %}

            {% block blur_elysium_slide_style_slide %}
                {{ selectorClass|raw }}[data-elysium-slide-id="{{ slideData.id }}"] {
                    {% if slideStyles is not empty %}
                        {% for prop, value in slideStyles|filter(v => v !== null) %}
                            {{prop}}: {{value}};
                        {% endfor %}
                    {% endif %}

                    {% block blur_elysium_slide_style_default_append %}{% endblock %}
                }
            {% endblock %}

            {% if slideViewportStyles is not null %}
                {% if device is defined %}
                    {# Preview mode: cumulative mobile-first output #}
                    {{ selectorClass|raw }}[data-elysium-slide-id="{{ slideData.id }}"] {
                        {% if slideViewportStyles.mobile is defined %}
                            {{ _self.outputViewportVars(slideViewportStyles.mobile, viewportMappings) }}
                        {% endif %}

                        {% if device in ['tablet', 'desktop'] and slideViewportStyles.tablet is defined %}
                            {{ _self.outputViewportVars(slideViewportStyles.tablet, viewportMappings) }}
                        {% endif %}

                        {% if device == 'desktop' and slideViewportStyles.desktop is defined %}
                            {{ _self.outputViewportVars(slideViewportStyles.desktop, viewportMappings) }}
                        {% endif %}
                    }
                {% else %}
                    {# Storefront mode: @media queries for all devices #}
                    {% for deviceBreakpoint, options in slideViewportStyles %}
                        @media (min-width: {{ theme_config('breakpoint.' ~ blurElysiumBreakpoints[deviceBreakpoint])~'px' }}) {
                            {{ selectorClass|raw }}[data-elysium-slide-id="{{ slideData.id }}"] {
                                {{ _self.outputViewportVars(options, viewportMappings) }}

                                {% block blur_elysium_slide_style_viewport_append %}{% endblock %}
                            }
                        }
                    {% endfor %}
                {% endif %}
            {% endif %}

            {% block blur_elysium_slide_style_append %}{% endblock %}
        </style>
    {% endblock %}
{% endapply %}
