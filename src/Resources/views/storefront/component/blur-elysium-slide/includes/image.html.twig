{% block blur_elysium_slide_image %}
    {% set focusImageId = slideData.contentSettings.focusImageId|default(null) %}
    {% set imageMedia = focusImageId and resolvedMedia ? (resolvedMedia|filter(m => m.id == focusImageId)|first|default(null)) : null %}

    {% if slideData.slideSettings.slide.linking.type is same as('product')
          and slideData.product.cover.media is not null
          and slideData.slideSettings.slide.linking.showProductFocusImage is same as(true) %}
        {% set imageMedia = slideData.product.cover.media %}
    {% elseif slideData.slideSettings.slide.linking.type is same as('category')
          and slideData.category.media is not null
          and slideData.slideSettings.slide.linking.showCategoryFocusImage is same as(true) %}
        {% set imageMedia = slideData.category.media %}
    {% endif %}

    {% if imageMedia %}
        <div class="blur-elysium-slide-image"
             data-elysium-slide-focus-image="{{ slideData.id }}">
            {% sw_thumbnails 'elysium-slide-focus-image' with {
                media: imageMedia,
                attributes: {
                    'loading': 'eager',
                    'class': 'd-block img-fluid',
                    'style': 'width: var(--slide-focus-image-w, 100%);'
                }
            } %}
        </div>
    {% endif %}
{% endblock %}
