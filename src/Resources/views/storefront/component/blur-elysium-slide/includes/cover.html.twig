{% set blurElysiumBreakpoints = {
    mobile: 'xs',
    tablet: 'md',
    desktop: 'xl'
} %}

{% if config('BlurElysiumSlider.breakpoints') %}
    {% set blurElysiumBreakpoints = blurElysiumBreakpoints|merge(config('BlurElysiumSlider.breakpoints')) %}
{% endif %}

{% set lazyLoading = lazyLoading|default(false) %}

{% set contentCover = slideData.contentSettings.slideCover|default({}) %}
{% set coverVideoId = contentCover.videoId|default(null) %}
{% set coverMobileId = contentCover.mobileId|default(null) %}
{% set coverTabletId = contentCover.tabletId|default(null) %}
{% set coverDesktopId = contentCover.desktopId|default(null) %}

{% set slideCoverVideo = coverVideoId and resolvedMedia ? (resolvedMedia|filter(m => m.id == coverVideoId)|first|default(null)) : null %}
{% set slideCoverMobile = coverMobileId and resolvedMedia ? (resolvedMedia|filter(m => m.id == coverMobileId)|first|default(null)) : null %}
{% set slideCoverTablet = coverTabletId and resolvedMedia ? (resolvedMedia|filter(m => m.id == coverTabletId)|first|default(null)) : null %}
{% set slideCoverDesktop = coverDesktopId and resolvedMedia ? (resolvedMedia|filter(m => m.id == coverDesktopId)|first|default(null)) : null %}

{% if slideCoverVideo %}
    <video autoplay muted loop
        class="blur-elysium-slide-cover-video"
        data-elysium-slide-cover-video="{{ slideData.id }}"
        style="border-radius: var(--slide-border-radius, 0px);">
        <source src="{{ slideCoverVideo.url }}" type="{{ slideCoverVideo.mimeType }}">
    </video>
{% else %}
    {% set slideCovers = {} %}
    {% if slideCoverMobile %}
        {% set slideCovers = slideCovers|merge({ mobile: slideCoverMobile }) %}
    {% endif %}
    {% if slideCoverTablet %}
        {% set slideCovers = slideCovers|merge({ tablet: slideCoverTablet }) %}
    {% endif %}
    {% if slideCoverDesktop %}
        {% set slideCovers = slideCovers|merge({ desktop: slideCoverDesktop }) %}
    {% endif %}

    {% if slideCovers|length > 0 %}
        {% set slideCoverAlt = slideCoverMobile.alt|default(
            slideCoverTablet.alt|default(
                slideCoverDesktop.alt|default(null)
            )
        ) %}
        {% set slideCoverTitle = slideCoverMobile.title|default(
            slideCoverTablet.title|default(
                slideCoverDesktop.title|default(null)
            )
        ) %}
        {% set slideCoverLabel = slideCoverAlt %}

        {% if contentCover.alt %}
            {% set slideCoverAlt = contentCover.alt %}
            {% set slideCoverLabel = contentCover.alt %}
        {% endif %}

        {% if contentCover.title %}
            {% set slideCoverTitle = contentCover.title %}
        {% endif %}

        <picture class="blur-elysium-slide-cover-picture">
            {% if slideCoverDesktop %}
                {% set coverThumbnails = slideCoverDesktop.metaData._thumbnails|default(slideCoverDesktop.thumbnails) %}
                <source
                    {% if coverThumbnails|length > 0 %}
                        srcset="{{ create_srcset(coverThumbnails) }}"
                    {% else %}
                        srcset="{{ slideCoverDesktop.url }}"
                    {% endif %}
                    media="screen and (min-width:{{ theme_config('breakpoint.' ~ blurElysiumBreakpoints.desktop)~'px' }})" />
            {% endif %}

            {% if slideCoverTablet %}
                {% set coverThumbnails = slideCoverTablet.metaData._thumbnails|default(slideCoverTablet.thumbnails) %}
                <source
                    {% if coverThumbnails|length > 0 %}
                        srcset="{{ create_srcset(coverThumbnails) }}"
                    {% else %}
                        srcset="{{ slideCoverTablet.url }}"
                    {% endif %}
                    media="screen and (min-width:{{ theme_config('breakpoint.' ~ blurElysiumBreakpoints.tablet)~'px' }})" />
            {% endif %}

            {% if slideCoverMobile %}
                {% set coverThumbnails = slideCoverMobile.metaData._thumbnails|default(slideCoverMobile.thumbnails) %}
                <img
                    src="{{ slideCoverMobile.url }}"
                    {% if coverThumbnails|length > 0 %}
                        srcset="{{ create_srcset(coverThumbnails) }}"
                    {% endif %}
                    width="100%"
                    height="100%"
                    {% if slideCoverAlt %}alt="{{ slideCoverAlt }}"{% endif %}
                    {% if slideCoverTitle %}title="{{ slideCoverTitle }}"{% endif %}
                    {% if slideCoverLabel %}aria-label="{{ slideCoverLabel }}"{% endif %}
                    class="blur-elysium-slide-cover-image"
                    data-elysium-slide-cover-image="{{ slideData.id }}"
                    style="border-radius: var(--slide-border-radius, 0px);"
                    {% if lazyLoading is same as(true) %}loading="lazy"{% endif %} />
            {% else %}
                <img
                    src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
                    width="100%"
                    height="100%"
                    class="blur-elysium-slide-cover-image"
                    data-elysium-slide-cover-image="{{ slideData.id }}"
                    style="border-radius: var(--slide-border-radius, 0px);"
                    {% if lazyLoading is same as(true) %}loading="lazy"{% endif %} />
            {% endif %}
        </picture>
    {% endif %}
{% endif %}
