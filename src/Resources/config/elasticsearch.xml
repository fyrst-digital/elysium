<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Elasticsearch Admin Search Indexer -->
        <service id="Blur\BlurElysiumSlider\Elasticsearch\Admin\Indexer\ElysiumSlidesAdminSearchIndexer"
        class="Blur\BlurElysiumSlider\Elasticsearch\Admin\Indexer\ElysiumSlidesAdminSearchIndexer">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopware\Core\Framework\DataAbstractionLayer\Dbal\Common\IteratorFactory"/>
            <argument type="service" id="blur_elysium_slides.repository"/>
            <argument>%elasticsearch.indexing_batch_size%</argument>
            <tag name="shopware.elastic.admin-searcher-index" key="blur_elysium_slides"/>
        </service>
    </services>
</container>
