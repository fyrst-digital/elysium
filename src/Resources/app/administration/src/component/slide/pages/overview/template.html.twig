<sw-page>
    <template #search-bar>
        <sw-search-bar
            initial-search-type="blur_elysium_slides"
            :initial-search="searchTerm"
            @search="onSearch"
        />
    </template>

    <template #smart-bar-header>
        <div :style="styles.moduleHeading">
            <blur-elysium-slides-icon :color="module.color"/>
            <h2>
                {{ $t('blurElysiumSlides.slideOverviewLabel') }}
                <span
                    :style="{
                        fontWeight: 'normal'
                    }"
                >
                    ({{ total }})
                </span>
            </h2>
        </div>
    </template>

    <template #language-switch>
        <sw-language-switch @on-change="onChangeLanguage"/>
    </template>

    <template #smart-bar-actions>
        <mt-button
            v-if="isImportExportEnabled && permissionExport"
            variant="secondary"
            size="default"
            v-tooltip="{ message: $tc('blurElysiumSlides.actions.exportSlidesTooltip') }"
            @click="onExportAll"
        >
            {{ $tc('blurElysiumSlides.actions.exportSlides') }}
        </mt-button>
        <mt-button
            v-if="isImportExportEnabled && permissionImport"
            variant="secondary"
            size="default"
            @click="onImportSlides"
        >
            {{ $tc('blurElysiumSlides.actions.importSlides') }}
        </mt-button>
        <mt-button
            variant="primary"
            size="default"
            :disabled="!permissionCreate"
            @click="$router.push({ name: 'blur.elysium.slides.create' })"
        >
            {{ $tc('blurElysium.action.createSlide') }}
        </mt-button>
    </template>

    <template #content>
        <sw-entity-listing
            v-if="total > 0"
            :items="slidesCollection"
            :repository="slidesRepository"
            :columns="slidesColumns"
            :is-loading="isLoading"
            :sort-by="currentSortBy"
            :sort-direction="sortDirection"
            :natural-sorting="naturalSorting"
            :allow-delete="permissionDelete"
            @column-sort="onColumnSort"
            @delete-item-finish="finishDeleteItems"
            @items-delete-finish="finishDeleteItems"
            @selection-change="onSelectionChange"
        >
            <template #bulk-additional="{ selectionCount }">
                <a
                    v-if="selectionCount > 0 && isImportExportEnabled && permissionExport"
                    class="link link-primary"
                    role="button"
                    tabindex="0"
                    @click="onBulkExport"
                    @keydown.enter="onBulkExport"
                >
                    {{ $tc('blurElysiumSlides.actions.exportSlides') }}
                </a>
            </template>
            <template #column-name="{ item }">
                <div :style="{ display: 'flex', alignItems: 'center', gap: '8px' }">
                    <router-link
                        v-if="permissionView"
                        :to="{ name: 'blur.elysium.slides.detail', params: { id: item.id } }"
                    >
                        {{ item.translated ? item.translated.name : item.name }}
                    </router-link>
                    <template v-else>{{ item.translated ? item.translated.name : item.name }}</template>
                    <py-icon 
                        v-if="getSlideHints(item).length > 0"
                        name="info-bold"
                        :size="14" 
                        :style="{
                            color: 'var(--color-icon-secondary-default)',
                            cursor: 'pointer'
                        }"
                        v-tooltip="{
                            message: getSlideHints(item).join('<br/>'),
                        }" />
                </div>
            </template>
            <template #column-contentSettings.title="{ item }">
                {{ displayContentSettings(item).title || '' }}
            </template>
            <template #more-actions="{ item }">
                <sw-context-menu-item
                    :disabled="!permissionCreate"
                    @click="copySlide(item)"
                >
                    {{ $tc('blurElysiumSlides.actions.copySlide') }}
                </sw-context-menu-item>
                <sw-context-menu-item
                    :disabled="!permissionView"
                    :router-link="permissionView === true ? { name: 'blur.elysium.slides.detail', params: { id: item.id }} : null"
                >
                    {{ $tc('blurElysiumSlides.actions.editSlide') }}
                </sw-context-menu-item>
            </template>
        </sw-entity-listing>
        <template v-if="isLoading === false && total === 0">
            <sw-empty-state
                :title="$tc('blurElysiumSlides.emptySlidesTitle')"
                :subline="$tc('blurElysiumSlides.emptySlidesSubline')"
                :auto-height="true"
                :style="{
                    minHeight: '50vh',
                    padding: '40px 20px'
                }"
            >
                <template #icon>
                    <img
                        :src="assetFilter('/administration/administration/static/img/empty-states/media-empty-state.svg')"
                        :alt="$tc('blurElysiumSlides.emptySlidesTitle')"
                    />
                </template>

                <template #actions>
                    <mt-button
                        variant="secondary"
                        size="default"
                        @click="$router.push({ name: 'blur.elysium.slides.create' })"
                    >
                        {{ $tc('blurElysium.action.createSlide') }}
                    </mt-button>
                </template>
            </sw-empty-state>
        </template>

        <sw-modal
            v-if="showImportModal"
            :title="$tc('blurElysiumSlides.importModal.title')"
            @modal-close="onCloseImportModal"
        >
            <p :style="{ marginBottom: '16px' }">
                {{ $tc('blurElysiumSlides.importModal.description') }}
            </p>
            <p
                v-if="$tc('blurElysiumSlides.importModal.overwriteWarning')"
                :style="{
                    marginBottom: '16px',
                    color: 'var(--color-text-warning)',
                    fontWeight: 'bold'
                }"
            >
                {{ $tc('blurElysiumSlides.importModal.overwriteWarning') }}
            </p>

            <sw-file-input
                :label="$tc('blurElysiumSlides.importModal.fileLabel')"
                @update:value="onImportFileChange"
            />

            <template #modal-footer>
                <mt-button
                    variant="secondary"
                    size="default"
                    @click="onCloseImportModal"
                >
                    {{ $tc('blurElysium.action.cancel') }}
                </mt-button>
                <mt-button
                    variant="primary"
                    size="default"
                    :disabled="!importFile || isImporting"
                    @click="onSubmitImport"
                >
                    {{ $tc('blurElysiumSlides.importModal.submit') }}
                </mt-button>
            </template>
        </sw-modal>
    </template>
</sw-page>
