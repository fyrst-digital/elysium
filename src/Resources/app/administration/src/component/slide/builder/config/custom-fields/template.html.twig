<py-section 
    padding
    gap
    :title="$tc('blurElysiumSlides.forms.customFields.label')"
    >

    <py-column v-if="customFieldSet && slide._isNew !== true">
        <sw-custom-field-set-renderer
            v-if="hasCustomFields"
            :entity="slide"
            :sets="customFieldSet"
        />
        <mt-banner
            v-else
            variant="attention"
            :closable="false"
        >
            {{ $tc('blurElysiumSlides.forms.customFields.emptyFieldSet') }}
        </mt-banner>
    </py-column>
    <py-column v-else>
        <mt-banner
            variant="info"
            :closable="false"
        >
            {{ $tc('blurElysiumSlides.forms.customFields.newSlide') }}
        </mt-banner>
    </py-column>
</py-section>