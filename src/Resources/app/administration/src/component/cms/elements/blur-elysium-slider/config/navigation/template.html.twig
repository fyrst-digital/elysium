<mt-banner
    v-if="navigationViewportConfig === null"
    :variant="'attention'"
>
    <div v-html="$tc('blurElysium.general.noViewportConfigAvailable')"/>
</mt-banner>
<py-section
    gap
    padding
>
    <py-column :cols="12">
        <mt-switch
            class="blur-switch-input"
            :checked="navigationConfig.active"
            :label="$tc('blurElysiumSlider.config.navigation.active')"
            @change="navigationConfig.active = $event"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-select-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.navigation.position.label')"
            :options="positions"
            v-model="navigationConfig.position"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-select-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.navigation.align.label')"
            :options="aligns"
            v-model="navigationConfig.align"
        />
    </py-column>
</py-section>
<py-section
    :title="$tc('blurElysium.general.appearance')"
    gap
    padding
>
    <py-column :cols="12" :cols-tablet="6">
        <py-select-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.navigation.shape.label')"
            :options="shapes"
            v-model="navigationConfig.shape"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-select-field
            v-if="navigationViewportConfig"
            layout="row"
            :label="$tc('blurElysiumSlider.config.navigation.size.label')"
            :placeholder="viewportsPlaceholder('navigation.size', 'md', 'blurElysium.general')"
            :options="sizes"
            v-model="navigationViewportConfig.size"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-number-field
            v-if="navigationViewportConfig"
            layout="row"
            :step="1"
            :min="0"
            :allow-empty="true"
            :model-value="navigationViewportConfig.gap"
            @update:model-value="value => navigationViewportConfig.gap = value"
            :label="$tc('blurElysiumSlider.config.navigation.navPadding.label')"
            :placeholder="viewportsPlaceholder('navigation.gap', 16)"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.color')"
            v-model:value="navigationConfig.colors.default"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.colorActive')"
            v-model:value="navigationConfig.colors.active"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
</py-section>
