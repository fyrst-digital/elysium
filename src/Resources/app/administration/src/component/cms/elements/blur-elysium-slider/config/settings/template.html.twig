<mt-banner
    v-if="settingsViewportConfig === null"
    :variant="'attention'"
>
    <div v-html="$tc('blurElysium.general.noViewportConfigAvailable')"/>
</mt-banner>
<py-section
    gap
    padding
    :title="$tc('blurElysiumSlider.config.settings.general')"
>
    {% block blur_cms_config_elysium_slider_rewind %}
        <py-column :cols="6">
            <mt-switch
                class="blur-switch-input"
                :label="$tc('blurElysiumSlider.config.settings.rewind')"
                :checked="settingsConfig.rewind"
                @change="settingsConfig.rewind = $event"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_overlay %}
        <py-column :cols="6">
            <mt-switch
                class="blur-switch-input"
                :label="$tc('blurElysiumSlider.config.settings.overlay')"
                :checked="settingsConfig.overlay"
                @change="settingsConfig.overlay = $event"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_justifySlideHeight %}
        <py-column :cols="12">
            <mt-switch
                class="blur-switch-input"
                :label="$tc('blurElysiumSlider.config.settings.justifySlideHeight')"
                :checked="settingsConfig.justifySlideHeight"
                @change="settingsConfig.justifySlideHeight = $event"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_slides_per_page %}
        <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
            <py-number-field
                v-if="settingsViewportConfig"
                layout="row"
                :label="$tc('blurElysiumSlider.config.settings.slidesPerPage.label')"
                :placeholder="viewportsPlaceholder('settings.slidesPerPage', 1)"
                :min="1"
                :step="1"
                :model-value="settingsViewportConfig.slidesPerPage"
                @update:model-value="value => settingsViewportConfig.slidesPerPage = value"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_speed %}
        <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
            <py-number-field
                numberType="int"
                layout="row"
                :label="$tc('blurElysiumSlider.config.settings.speed.label')"
                :step="null"
                :min="300"
                :max="null"
                :digits="null"
                :allowEmpty="false"
                :model-value="settingsConfig.speed"
                @update:model-value="value => settingsConfig.speed = value"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_container_width %}
        <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
            <py-select-field
                v-model="settingsConfig.containerWidth"
                layout="row"
                :label="$tc('blurElysiumSlider.config.settings.containerWidth.label')"
                :tooltip="$tc('blurElysiumSlider.config.settings.containerWidth.helpText')"
                :options="[
                    { value: 'content', label: $tc('blurElysiumSlider.config.settings.containerWidth.content') },
                    { value: 'full', label: $tc('blurElysiumSlider.config.settings.containerWidth.full') }
                ]"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_slide_effect %}
        <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
            <py-select-field
                v-model="settingsConfig.slideEffect"
                layout="row"
                :label="$tc('blurElysiumSlider.config.settings.slideEffect.label')"
                :tooltip="$tc('blurElysiumSlider.config.settings.slideEffect.helpText')"
                :options="[
                    { value: 'slide', label: $tc('blurElysiumSlider.config.settings.slideEffect.slide') },
                    { value: 'fade', label: $tc('blurElysiumSlider.config.settings.slideEffect.fade') }
                ]"
            />
        </py-column>
    {% endblock %}

    <py-column :cols="6">
        <py-text-field
            layout="row"
            :label="$tc('blurElysium.general.cssClasses.label')"
            :placeholder="$tc('blurElysium.general.cssClasses.placeholder')"
            :tooltip="$tc('blurElysium.general.cssClasses.helpText')"
            v-model="settingsConfig.cssClasses"
        />
    </py-column>
</py-section>
<py-section
    gap
    padding
    :title="$tc('blurElysiumSlider.config.settings.autoplay.label')"
>
    {% block blur_cms_config_elysium_slider_autoplay_active %}
        <py-column :cols="12" :cols-tablet="6">
            <mt-switch
                class="blur-switch-input"
                :label="$tc('blurElysiumSlider.config.settings.autoplay.active')"
                :checked="settingsConfig.autoplay.active"
                @change="settingsConfig.autoplay.active = $event"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_autoplay_pause_on_hover %}
        <py-column :cols="12" :cols-tablet="6">
            <mt-switch
                class="blur-switch-input"
                :label="$tc('blurElysiumSlider.config.settings.autoplay.pauseOnHover')"
                :checked="settingsConfig.autoplay.pauseOnHover"
                @change="settingsConfig.autoplay.pauseOnHover = $event"
            />
        </py-column>
    {% endblock %}

    {% block blur_cms_config_elysium_slider_autoplay_timeout %}
        <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
            <py-number-field
                numberType="int"
                layout="row"
                :label="$tc('blurElysiumSlider.config.settings.autoplay.interval.label')"
                :placeholder="$tc('blurElysiumSlider.config.settings.autoplay.interval.placeholder')"
                :step="null"
                :min="200"
                :max="null"
                :digits="null"
                :allowEmpty="false"
                :model-value="settingsConfig.autoplay.interval"
                @update:model-value="value => settingsConfig.autoplay.interval = value"
            />
        </py-column>
    {% endblock %}
</py-section>
