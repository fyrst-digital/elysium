<mt-banner
    v-if="sizingViewportConfig === null"
    :variant="'attention'"
>
    <div v-html="$tc('blurElysium.general.noViewportConfigAvailable')"/>
</mt-banner>
<py-section
    v-if="sizingViewportConfig"
    gap
    padding
    :title="$tc('blurElysiumSlider.config.sizing.aspectRatio.label')"
    :description="$tc('blurElysiumSlider.config.sizing.aspectRatio.description')"
>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.sizing.aspectRatio.width')"
            :placeholder="viewportsPlaceholder('sizing.aspectRatio.width', 4)"
            :model-value="sizingViewportConfig.aspectRatio.width"
            :step="1"
            :min="0"
            :allow-empty="true"
            @update:model-value="value => sizingViewportConfig.aspectRatio.width = value"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.sizing.aspectRatio.height')"
            :placeholder="viewportsPlaceholder('sizing.aspectRatio.height', 3)"
            :model-value="sizingViewportConfig.aspectRatio.height"
            :step="1"
            :min="0"
            :allow-empty="true"
            @update:model-value="value => sizingViewportConfig.aspectRatio.height = value"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.sizing.maxHeight.label')"
            :placeholder="viewportsPlaceholder('sizing.maxHeight', 'noLimit', 'blurElysium.general')"
            :model-value="sizingViewportConfig.maxHeight"
            :allow-empty="true"
            :step="1"
            :min="0"
            @update:model-value="value => sizingViewportConfig.maxHeight = value"
        />
    </py-column>
</py-section>
<py-section
    v-if="sizingViewportConfig"
    gap
    padding
    :title="$tc('blurElysiumSlider.config.sizing.spacing.label')"
>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.sizing.spacing.slidesGap.label')"
            :placeholder="viewportsPlaceholder('sizing.slidesGap', 0)"
            :allow-empty="true"
            :step="1"
            :min="0"
            :model-value="sizingViewportConfig.slidesGap"
            @update:model-value="value => sizingViewportConfig.slidesGap = value"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysium.general.paddingY')"
            :placeholder="viewportsPlaceholder('sizing.paddingY', 24)"
            :step="1"
            :min="0"
            :allow-empty="true"
            :model-value="sizingViewportConfig.paddingY"
            @update:model-value="value => sizingViewportConfig.paddingY = value"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="4">
        <py-number-field
            layout="row"
            :label="$tc('blurElysium.general.paddingX')"
            :placeholder="viewportsPlaceholder('sizing.paddingX', 24)"
            :step="1"
            :min="0"
            :allow-empty="true"
            :model-value="sizingViewportConfig.paddingX"
            @update:model-value="value => sizingViewportConfig.paddingX = value"
        />
    </py-column>
</py-section>
