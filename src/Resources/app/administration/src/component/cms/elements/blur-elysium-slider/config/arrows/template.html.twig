<mt-banner
    v-if="arrowsViewportConfig === null"
    :variant="'attention'"
>
    <div v-html="$tc('blurElysium.general.noViewportConfigAvailable')"/>
</mt-banner>
<py-section
    gap
    padding
>
    <py-column :cols="12">
        <mt-switch
            class="blur-switch-input"
            :checked="arrowsConfig.active"
            :label="$tc('blurElysiumSlider.config.arrows.active')"
            @change="arrowsConfig.active = $event"
        />
    </py-column>
</py-section>
<py-section
    :title="$tc('blurElysium.general.appearance')"
    gap
    padding
>
    <py-column :cols="12" :cols-tablet="6">
        <py-select-field
            layout="row"
            :label="$tc('blurElysiumSlider.config.arrows.icons.label')"
            :placeholder="$tc('blurElysiumSlider.config.arrows.icons.chevron')"
            :options="icons"
            v-model="arrowsConfig.icon.default"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-number-field
            v-if="arrowsViewportConfig"
            layout="row"
            :step="1"
            :min="0"
            :allow-empty="true"
            :model-value="arrowsViewportConfig.iconSize"
            @update:model-value="value => arrowsViewportConfig.iconSize = value"
            :placeholder="viewportsPlaceholder('arrows.iconSize', 24)"
            :label="$tc('blurElysiumSlider.config.arrows.size.label')"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-number-field
            v-if="arrowsViewportConfig"
            layout="row"
            :step="1"
            :min="0"
            :allow-empty="true"
            :model-value="arrowsViewportConfig.offsetPadding"
            @update:model-value="value => arrowsViewportConfig.offsetPadding = value"
            :placeholder="viewportsPlaceholder('arrows.offsetPadding', 24)"
            :label="$tc('blurElysiumSlider.config.arrows.offsetPadding.label')"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.iconColor')"
            v-model:value="arrowsConfig.colors.default"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.iconColorActive')"
            v-model:value="arrowsConfig.colors.active"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.bgColor')"
            v-model:value="arrowsConfig.bgColors.default"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
    <py-column :cols="12" :cols-tablet="6" :cols-desktop="6">
        <py-colorpicker-field
            layout="row"
            :label="$tc('blurElysium.general.bgColorActive')"
            v-model:value="arrowsConfig.bgColors.active"
            colorOutput="auto"
            :alpha="true"
            :disabled="false"
            :colorLabels="true"
            :zIndex="1010"
        />
    </py-column>
</py-section>
