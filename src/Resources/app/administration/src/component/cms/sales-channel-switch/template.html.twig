<div :style="{
    display: 'flex',
    alignItems: 'center',
    gap: '8px',
}">
    <mt-loader
        v-if="isLoading"
        size="24px"
    />

    <template v-else-if="hasAvailableDomains">
        <div
            :style="{
                lineHeight: '1',
                fontSize: '12px',
                fontWeight: '500',
            }"
        >
            {{ $tc('blurElysiumSlides.salesChannel.label') }}
        </div>

        <py-select-field
            layout="row"
            :model-value="selectedSalesChannelId"
            @update:model-value="onSalesChannelChange"
            :options="salesChannels.map(channel => ({ value: channel.id, label: channel.name }))"
            :style="{
                maxWidth: '200px',
            }"
        />
    </template>

    <template v-else>
        <mt-icon
            name="regular-exclamation-triangle"
            size="16px"
            color="#ff0000"
        />
        <span :style="{
            fontSize: '12px',
            color: 'var(--color-text-secondary-default)',
        }">
            {{ $tc('blurElysiumSlides.preview.noDomainAvailableTitle') }}
        </span>
    </template>
</div>
