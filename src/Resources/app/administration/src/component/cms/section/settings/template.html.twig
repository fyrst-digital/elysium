<py-section
  padding
  gap
  :style="{
    '--py-section-gap-y': '8px',
    '--container-gap-y': '12px',
    'border-bottom': '1px solid var(--color-border-secondary-default)',
  }"
>
  <py-column>
    <py-select-field
      :label="$tc('blurElysium.general.blockAlignment')"
      :placeholder="viewportsPlaceholder('alignItems', 'stretch', 'blurElysium.general.alignItems')"
      :options="[
        { value: 'stretch', label: $tc('blurElysium.general.alignItems.stretch') },
        { value: 'flex-start', label: $tc('blurElysium.general.alignItems.flexStart') },
        { value: 'center', label: $tc('blurElysium.general.alignItems.center') },
        { value: 'flex-end', label: $tc('blurElysium.general.flexEnd') },
      ]"
      v-model="currentViewportSettings.alignItems"
    />
  </py-column>
  <py-column>
    <py-number-field
      :label="$tc('blurElysium.general.gap')"
      :placeholder="viewportsPlaceholder('gridGap', 20)"
      v-model="currentViewportSettings.gridGap"
      @update:model-value="value => currentViewportSettings.gridGap = value"
    />
  </py-column>
  <py-column>
    <py-number-field
      :label="$tc('blurElysium.general.paddingY')"
      :placeholder="viewportsPlaceholder('paddingY', 0)"
      v-model="currentViewportSettings.paddingY"
      @update:model-value="value => currentViewportSettings.paddingY = value"
    />
  </py-column>
  <py-column>
    <py-number-field
      :label="$tc('blurElysium.general.paddingX')"
      :placeholder="viewportsPlaceholder('paddingX', 0)"
      v-model="currentViewportSettings.paddingX"
      @update:model-value="value => currentViewportSettings.paddingX = value"
    />
  </py-column>
</py-section>
<py-section
  padding
  gap
  :title="$tc('blurElysiumSection.sidebar.sectionSettings.breakpoints.title')"
  :description="$tc('blurElysiumSection.sidebar.sectionSettings.breakpoints.description')"
  :style="{
    '--py-section-gap-y': '8px',
    '--container-gap-y': '12px',
    'border-bottom': '1px solid var(--color-border-secondary-default)',
  }"
>
  <py-column>
    <py-select-field
      :tooltip="$tc('blurElysiumSection.sidebar.sectionSettings.breakpoints.tabletHelptext')"
      :label="'Tablet'"
      :placeholder="'md'"
      :options="optionsBreakpoints"
      v-model="settings.breakpoints.tablet"
    />
  </py-column>
  <py-column>
    <py-select-field
      :tooltip="$tc('blurElysiumSection.sidebar.sectionSettings.breakpoints.desktopHelptext')"
      :label="'Desktop'"
      :placeholder="'xl'"
      :options="optionsBreakpoints"
      v-model="settings.breakpoints.desktop"
    />
  </py-column>
</py-section>
<py-section
  v-if="isTimeControlActive"
  padding
  gap
  :title="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.label')"
  :style="{
    '--py-section-gap-y': '8px',
    '--container-gap-y': '12px',
    'border-bottom': '1px solid var(--color-border-secondary-default)',
  }"
>
  <py-column>
    <py-datepicker
      :label="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeFrom.label')"
      :placeholder="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeFrom.placeholder')"
      :tooltip="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeFrom.helpText')"
      :model-value="settings.activeFrom"
      @update:model-value="settings.activeFrom = $event"
    />
  </py-column>
  <py-column>
    <py-datepicker
      :label="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeUntil.label')"
      :placeholder="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeUntil.placeholder')"
      :tooltip="$tc('blurElysiumSection.sidebar.sectionSettings.timeControl.activeUntil.helpText')"
      :model-value="settings.activeUntil"
      @update:model-value="settings.activeUntil = $event"
    />
  </py-column>
</py-section>
