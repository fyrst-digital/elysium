<div
    :class="[
        'py-section',
        padding === true ? 'has-padding' : null,
        gap === true ? 'has-gap' : null,
        gapY === true ? 'has-gap-y' : null,
        gapX === true ? 'has-gap-x' : null
    ]"
>
    <slot name="header">
        <div
            :class="['py-section-header']"
            v-if="title || description"
        >
            <slot name="title">
                <div
                    :class="['py-section-title']"
                    v-if="title"
                >
                    <slot name="title-prepend" />
                    <py-icon
                        v-if="titleIcon"
                        :name="titleIcon"
                        size="16"
                        color="#189eff"
                    />
                    <span v-html="title"/>
                    <slot name="title-append" />
                </div>
            </slot>
            <slot name="description">
                <div
                    :class="['py-section-description']"
                    v-if="description"
                    v-html="description"
                />
            </slot>
        </div>
    </slot>
    <div :class="['py-section-content']">
        <slot/>
    </div>
</div>
